amends "package://github.com/jdx/hk/releases/download/v1.1.1/hk@1.1.1#/Config.pkl"

local linters = new Mapping<String, Step> {
  ["fmt"] {
    fix = "dprint fmt"
    stage = "*"
  }
  ["shellcheck"] {
    check = "shellcheck"
    glob = "{**/*.sh,**/*.bash,setup}"
  }
}

hooks {
  ["pre-commit"] {
    fix = true
    stash = "git"
    steps = linters
  }
}
